    "npm": "^11.13.0",
    "react": "19.2.0",
    "resend": "^6.7.0",
    "zod": "^4.3.5"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "expo": "~55.0.0"
  }
}
